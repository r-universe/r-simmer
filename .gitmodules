[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "simmer"]
	path = simmer
	url = https://github.com/r-simmer/simmer
	shallow = true
[submodule "simmer.bricks"]
	path = simmer.bricks
	url = https://github.com/r-simmer/simmer.bricks
	shallow = true
[submodule "simmer.plot"]
	path = simmer.plot
	url = https://github.com/r-simmer/simmer.plot
	shallow = true
